// Tokenstok-cabinet Prisma schema.
// NextAuth.js v5 uses JWT sessions — no Session/Account tables needed.
// Verification + magic-link + reset tokens are stored alongside the User.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]  // alpine in Dockerfile
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  emailVerified   DateTime?
  name            String?
  // Optional: users who sign up via magic link have no password yet.
  hashedPassword  String?
  balance         Decimal  @default(100) @db.Decimal(10, 2)  // 100 ₽ welcome credit
  role            String   @default("user")                  // "user" | "admin"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    Transaction[]
  usageEvents     UsageEvent[]
  magicTokens     MagicLinkToken[]
  verifyTokens    EmailVerificationToken[]
  resetTokens     PasswordResetToken[]

  @@index([email])
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// Финансовая транзакция: пополнение или списание. Сумма со знаком —
// положительная для пополнения, отрицательная для списания.
model Transaction {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind               String   // "topup" | "spend" | "refund" | "bonus"
  amountRub          Decimal  @db.Decimal(12, 4)
  balanceAfter       Decimal  @db.Decimal(12, 4)
  status             String   // "pending" | "succeeded" | "failed" | "cancelled"
  paymasterInvoiceId String?  @unique
  paymasterPaymentId String?
  description        String?
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  usageEvents        UsageEvent[]

  @@index([userId, createdAt])
  @@index([paymasterInvoiceId])
}

// Атомарное событие использования модели — для аналитики и аудита.
model UsageEvent {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId         String
  messageId      String?
  modelId        String   // наш id (например "claude-sonnet-4.5")
  gatewayModelId String   // provider id (например "anthropic/claude-sonnet-4.5")
  inputTokens    Int
  outputTokens   Int
  costRub        Decimal  @db.Decimal(12, 6)
  rawCostUsd     Decimal? @db.Decimal(12, 6)
  markup         Decimal  @db.Decimal(4, 3)  // наценка (1.300 = 30 %)
  transactionId  String?
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([chatId])
}
